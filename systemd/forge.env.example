# Example environment file for the forge-api systemd service.
# Install:  sudo cp systemd/forge.env.example /etc/forge/forge.env && sudo chmod 600 /etc/forge/forge.env
# Edit DATABASE_URL, FORGE_TOOLS_EXTENSION, and PATH for your host.

# --- Required ---
# PostgreSQL connection string. The role needs CREATE on the database
# (for first-time schema creation) and CREATE EXTENSION for pgcrypto.
DATABASE_URL=postgres://postgres@localhost/forge

# --- Optional but recommended ---
# Base URL the extension uses to call back into the API. Should match
# the address axum binds to (default 0.0.0.0:8080).
FORGE_API_URL=http://localhost:8080

# Absolute path to the built TypeScript extension. If unset, the binary
# falls back to a hard-coded search under
#   /root/.nvm/versions/node/v20.18.1/lib/node_modules/@earendil-works/pi-coding-agent/...
# and will fail if the install path differs.
FORGE_TOOLS_EXTENSION=/data/jbutler/git/jbutlerdev/forge/extensions/forge-tools/dist/index.js

# tracing-subscriber filter. Examples:
#   info                          (default)
#   forge_api=debug,info          (verbose harness + tool execution)
#   forge_api=trace,sqlx=warn     (full trace, suppress sqlx noise)
RUST_LOG=forge_api=debug,info

# PATH must include the directory containing the `pi` binary, otherwise
# the harness spawn fails with "pi: not found". On this dev box pi
# lives under nvm:
PATH=/root/.nvm/versions/node/v20.18.1/bin:/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin

# --- Provider keys (only required by profiles that use the matching provider) ---
# With provider=proxy-anthropic the API key is stored on the profile
# itself; these globals are only consulted when provider=anthropic or
# provider=openai.
# ANTHROPIC_API_KEY=sk-ant-...
# OPENAI_API_KEY=sk-...
