# Rust
/target/
**/*.rs.bk
*.pdb
# Cargo.lock is committed for binary crates so the CI cache key is
# stable and builds are reproducible. (It should stay ignored for
# library crates that have downstream consumers; forge-api is a
# binary, so we commit it.)

# IDE
.idea/
.vscode/
*.swp
*.swo
*~
.DS_Store

# Build artifacts
*.o
*.so
*.dylib
*.dll

# Environment
.env
.env.local
.env.*.local

# Logs
*.log
logs/

# Session directories (created at runtime)
/forge/sessions/
/parent.jsonl
/.parent.jsonl

# Node modules (in extensions)
/extensions/forge-tools/node_modules/

# Nix
result
result-*

# Temporary files
*.tmp
*.bak
*.cache

# Database
*.db
*.sqlite

# Test coverage
/coverage/
*.lcov
