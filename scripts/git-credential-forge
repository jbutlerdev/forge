#!/bin/sh
# Git credential helper for forge-api: provides the operator's
# `FORGE_GITHUB_TOKEN` (from /etc/forge/forge.env) to git when
# it clones / pulls / pushes to github.com from the host. Other
# hosts are no-ops (git falls back to whatever else is
# configured, or prompts; on the host a missing PAT for a
# non-github host is a 401, not a hang).
#
# This is the host-side counterpart to
# /forge/sandbox/base/usr/local/bin/git-credential-github in
# the per-session rootfs; the in-container helper reads
# `$GITHUB_TOKEN` (set via `nspawn --setenv`), this one reads
# `$FORGE_GITHUB_TOKEN` (set in /etc/forge/forge.env, the
# operator's env file). The token is read at git invocation
# time, so rotating the token and restarting forge-api (or
# just waiting for the next git call in a long-lived process)
# takes effect without rewriting this file.
#
# We deliberately don't `store` the credential: persisting it
# to ~/.git-credentials would put the token in a file that
# could be read inside a session sandbox or accidentally
# included in a tarball / log / process listing. Env-only is
# the right trade for both the host and the container.
#
# Installed by scripts/install.sh as
# /usr/local/bin/git-credential-github so that
# `git -c credential.helper=/usr/local/bin/git-credential-github`
# works with the standard git credential-helper lookup
# convention (`git credential-<helper>` → `git-credential-<helper>`
# on PATH).
case "$1" in
    get)
        # Parse the request from stdin (one key=value per
        # line, blank line terminates).
        host=""
        protocol=""
        while IFS= read -r line; do
            case "$line" in
                host=*)     host="${line#host=}" ;;
                protocol=*) protocol="${line#protocol=}" ;;
                "")         break ;;
            esac
        done
        # Only authenticate github.com over HTTPS. The PAT is
        # operator-controlled and only valid for github.com;
        # sending it to a third-party host would leak it to
        # whatever server is being cloned (or to the
        # /var/log/auth.log of whoever runs the helper).
        if [ "$host" = "github.com" ] && [ "$protocol" = "https" ] && [ -n "$FORGE_GITHUB_TOKEN" ]; then
            echo "username=x-access-token"
            echo "password=$FORGE_GITHUB_TOKEN"
        fi
        # Always exit 0 — a missing token should be silent,
        # not a hard error (git falls back to other helpers
        # or prompts the operator, neither of which is a
        # crash). A no-op `get` is the documented git
        # credential-helper contract for "I have no
        # credentials for this host".
        exit 0
        ;;
    store|erase)
        # No-op: the token lives in env, not a file. `store`
        # would normally write to ~/.git-credentials; we
        # never want that. `erase` would clear the same file;
        # also not applicable. Returning 0 tells git "ok,
        # nothing to do" rather than failing the operation.
        exit 0
        ;;
esac
exit 0
