#!/usr/bin/env bash
# Forge CLI - Example client for Forge API
#
# This is a simple CLI example. Forge is primarily an API server.
# Use this CLI or build your own client.

set -e

FORGE_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
FORGE_API_URL="${FORGE_API_URL:-http://localhost:8080}"

export FORGE_API_URL

source "${FORGE_DIR}/forge.d/common.sh"

# ============================================
# CLI Functions
# ============================================

cmd_messages() {
    local session_id="$1"
    [ -z "$session_id" ] && { echo "Usage: forge messages <session_id>"; exit 1; }
    
    local response=$(api_get "/messages?session_id=$session_id")
    local http_code="${response##*|}"
    local body="${response%|*}"
    
    if is_success "$http_code"; then
        if command -v jq &> /dev/null; then
            echo "$body" | jq -r '.messages[] | "[\(.role)] \(.created_at // "")\n\(.content // "[tool call: \(.tool_name // "")]")\n"'
        else
            echo "$body" | pretty_json
        fi
    else
        error "Failed to list messages: $body"
    fi
}

cmd_health() {
    local response=$(curl -s -w "|%{http_code}" "${FORGE_API_URL}/health")
    local http_code="${response##*|}"
    [ "$http_code" = "200" ] && success "API is healthy" || error "API is unhealthy (HTTP $http_code)"
}

cmd_status() {
    echo "Forge API Status"
    echo "================="
    echo ""
    echo "  API URL:    $FORGE_API_URL"
    
    local health_response=$(curl -s -o /dev/null -w "%{http_code}" "${FORGE_API_URL}/health" 2>/dev/null || echo "000")
    [ "$health_response" = "200" ] && echo -e "  Status:      \033[0;32m● Online\033[0m" || echo -e "  Status:      \033[0;31m● Offline\033[0m"
    
    local metrics_response=$(api_get "/metrics")
    local metrics_code="${metrics_response##*|}"
    if is_success "$metrics_code"; then
        local metrics_body="${metrics_response%|*}"
        if command -v jq &> /dev/null; then
            local sessions=$(echo "$metrics_body" | jq -r '.metrics.active_sessions // 0')
            local agents=$(echo "$metrics_body" | jq -r '.metrics.active_agents // 0')
            echo ""
            echo "  Active Sessions: $sessions"
            echo "  Active Agents:   $agents"
        fi
    fi
    echo ""
}

cmd_metrics() {
    local response=$(api_get "/metrics")
    local http_code="${response##*|}"
    local body="${response%|*}"
    
    if is_success "$http_code"; then
        if command -v jq &> /dev/null; then
            local requests=$(echo "$body" | jq -r '.metrics.requests_total // 0')
            local errors=$(echo "$body" | jq -r '.metrics.errors_total // 0')
            local tools=$(echo "$body" | jq -r '.metrics.tool_executions_total // 0')
            local sessions=$(echo "$body" | jq -r '.metrics.active_sessions // 0')
            local agents=$(echo "$body" | jq -r '.metrics.active_agents // 0')
            local error_rate=$(echo "$body" | jq -r '.error_rate // "0%"')
            
            echo "Forge API Metrics"
            echo "=================="
            echo ""
            echo "  Requests:        $requests"
            echo "  Errors:          $errors"
            echo "  Error Rate:      $error_rate"
            echo "  Tool Calls:      $tools"
            echo "  Active Sessions: $sessions"
            echo "  Active Agents:   $agents"
            echo ""
        else
            echo "$body" | pretty_json
        fi
    else
        error "Failed to get metrics: $body"
    fi
}

cmd_login() {
    local email="$1" password="$2"
    [ -z "$email" ] || [ -z "$password" ] && { echo "Usage: forge login <email> <password>"; exit 1; }
    
    local payload=$(jq -n --arg email "$email" --arg password "$password" '{email: $email, password: $password}')
    local response=$(api_post "/auth/login" "$payload")
    local http_code="${response##*|}"
    local body="${response%|*}"
    
    if is_success "$http_code"; then
        success "Login successful!"
        if command -v jq &> /dev/null; then
            local api_key=$(echo "$body" | jq -r '.api_key // empty')
            [ -n "$api_key" ] && echo "" && echo "  API Key: $api_key" && echo "" && echo "  Set: export FORGE_API_KEY='$api_key'"
        fi
    else
        error "Login failed: $body"
    fi
}

cmd_register() {
    local email="$1" name="$2" password="$3"
    [ -z "$email" ] || [ -z "$name" ] || [ -z "$password" ] && { echo "Usage: forge register <email> <name> <password>"; exit 1; }
    
    local payload=$(jq -n --arg email "$email" --arg name "$name" --arg password "$password" '{email: $email, name: $name, password: $password}')
    local response=$(api_post "/auth/register" "$payload")
    local http_code="${response##*|}"
    local body="${response%|*}"
    
    if is_success "$http_code"; then
        success "Registration successful!"
        if command -v jq &> /dev/null; then
            local api_key=$(echo "$body" | jq -r '.api_key // empty')
            [ -n "$api_key" ] && echo "" && echo "  API Key: $api_key" && echo "" && echo "  Set: export FORGE_API_KEY='$api_key'"
        fi
    else
        error "Registration failed: $body"
    fi
}

# ============================================
# Main
# ============================================

if [ $# -eq 0 ]; then
    show_help
    exit 0
fi

COMMAND="$1"
shift

case "$COMMAND" in
    profile)
        source "${FORGE_DIR}/forge.d/profile.sh"
        cmd_profile "$@"
        ;;
    session)
        source "${FORGE_DIR}/forge.d/session.sh"
        cmd_session "$@"
        ;;
    message)
        source "${FORGE_DIR}/forge.d/message.sh"
        cmd_message "$@"
        ;;
    messages)
        cmd_messages "$@"
        ;;
    agent)
        source "${FORGE_DIR}/forge.d/agent.sh"
        cmd_agent "$@"
        ;;
    health)
        cmd_health
        ;;
    status)
        cmd_status
        ;;
    metrics)
        cmd_metrics
        ;;
    login)
        cmd_login "$@"
        ;;
    register)
        cmd_register "$@"
        ;;
    -h|--help|help)
        show_help
        ;;
    *)
        echo "Unknown command: $COMMAND"
        show_help
        exit 1
        ;;
esac
